APP_ENV=local
DATABASE_URL=sqlite:///data/bookmarks.db
REQUEST_TIMEOUT=8

# IA opcional (apagada por defecto). Dejá OPENAI_API_KEY vacío para usar solo reglas locales.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Tope de seguridad de cuántos bookmarks enriquece la IA (clasifica todos hasta acá).
AI_MAX_BOOKMARKS=200
# Bookmarks por llamada a la IA (batch). Más alto = más barato/rápido, payload más grande.
AI_BATCH_SIZE=20
AI_TIMEOUT_SECONDS=30
# Confianza mínima de la IA para confiar en su criterio (gate de blending y flag de dudosos).
AI_MIN_CONFIDENCE=0.7
# Peso de la prioridad IA al fusionarla con el score local (0=solo local, 1=solo IA).
AI_BLEND_WEIGHT=0.6
# Ruta del perfil de usuario que se inyecta en el prompt (relativa a la raíz del repo).
PERFIL_PATH=perfil.md
